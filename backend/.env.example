# ─────────────────────────────────────────────────────────────────────────────
#  BACKEND ENVIRONMENT VARIABLES — .env.example
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development                  # Change to "production" on Koyeb

# MongoDB Atlas
# Get this from: MongoDB Atlas → Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/raj_dental?retryWrites=true&w=majority

# JWT Secrets
# ⚠️  ROTATE THESE FOR PRODUCTION — use a 64-char random hex string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_strong_64_char_secret
REFRESH_SECRET=replace_with_another_strong_64_char_secret

# CORS — Comma-separated list of allowed frontend origins (no spaces)
# Dev example:   http://localhost:3000,http://localhost:3001
# Prod example:  https://rajdental.in,https://www.rajdental.in,https://raj-dental-pms.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
